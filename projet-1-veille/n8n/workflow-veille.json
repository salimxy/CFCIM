{
  "name": "CFCIM - Veille économique quotidienne",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 8 * * 1-5" }]
        }
      },
      "id": "trigger-cron",
      "name": "Lundi–Vendredi à 8h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [200, 300]
    },
    {
      "parameters": {
        "command": "node /workflows/veille/src/collect.js"
      },
      "id": "collect",
      "name": "Collecte RSS",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [420, 300]
    },
    {
      "parameters": {
        "command": "node /workflows/veille/src/classify.js"
      },
      "id": "classify",
      "name": "Classification Claude",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [640, 300]
    },
    {
      "parameters": {
        "command": "node /workflows/veille/src/generate-email.js"
      },
      "id": "email",
      "name": "Génération email HTML",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [860, 300]
    }
  ],
  "connections": {
    "Lundi–Vendredi à 8h": { "main": [[{ "node": "Collecte RSS", "type": "main", "index": 0 }]] },
    "Collecte RSS": { "main": [[{ "node": "Classification Claude", "type": "main", "index": 0 }]] },
    "Classification Claude": { "main": [[{ "node": "Génération email HTML", "type": "main", "index": 0 }]] }
  }
}
